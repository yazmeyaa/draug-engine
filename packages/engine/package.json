{
  "name": "@draug/engine",
  "version": "1.0.29",
  "type": "module",
  "author": {
    "name": "future_undefined",
    "email": "evgenijantonenkov456@gmail.com",
    "url": "https://github.com/yazmeyaa"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yazmeyaa/draug-engine.git",
    "directory": "packages/engine"
  },
  "description": "Draug Engine is a TypeScript game engine focused on clear ECS-based architecture and reusable gameplay building blocks.",
  "license": "Apache-2.0",
  "readme": "README.md",
  "dependencies": {
    "bitmap-index": "^1.0.9"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./std-components": {
      "import": "./dist/std/components/index.js",
      "require": "./dist/std/components/index.cjs"
    },
    "./std-math": {
      "import": "./dist/std/math/index.js",
      "require": "./dist/std/math/index.cjs"
    },
    "./std-systems": {
      "import": "./dist/std/systems/index.js",
      "require": "./dist/std/systems/index.cjs"
    },
    "./std-utils": {
      "import": "./dist/std/utils/index.js",
      "require": "./dist/std/utils/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
